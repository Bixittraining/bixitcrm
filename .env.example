# Client-side (Vite exposes anything prefixed VITE_ to the browser bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Vercel serverless functions in /api — never prefix with VITE_)
# Used by api/create-team-member.js and every api/webhooks/* + api/integrations/*
# endpoint to bypass RLS after verifying the caller is an admin.
SUPABASE_SERVICE_ROLE_KEY=

# Per-integration webhook credentials (App ID/Secret, Page/Phone ID, access
# tokens, webhook verify tokens/keys) are NOT set here — they live in the
# `integrations` table (supabase/migrations/0004_integrations.sql) and are
# configured from Settings > Integrations in the app itself, via the
# api/integrations/* admin-only endpoints.
